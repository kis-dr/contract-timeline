[{"code":"005860","date":"2026-07-14","company_name":"한일사료","article_title":"호르무즈 재봉쇄에 해운·사료주 다시 뜬다…줄줄이 '상한가'","briefing":"한일사료의 주가가 4.03% 상승하여 2,580원에 마감되었습니다. 이 상승은 중동 지역의 군사적 긴장 고조로 인해 사료 및 비료 관련 종목들이 급등한 데 따른 것으로 보입니다. 호르무즈 해협 봉쇄 우려가 해상 물류 차질을 초래할 경우, 사료 원료 수급 불안이 부각되며 투자자들이 매수에 나선 것으로 분석됩니다.","content_url":"https://www.newsis.com/view/NISX20260714_0003708340","publisher":"뉴시스","polarity":null,"change_rate":4.03,"created_at":"2026-07-14T10:52:59.000000"},{"code":"005860","date":"2026-07-15","company_name":"한일사료","article_title":"중동 군사적 긴장 고조에…사료·비료株도 '급등'","briefing":"한일사료의 주가가 2.71% 하락하여 2,510원에 마감되었습니다. 이 하락세는 중동 지역의 군사적 긴장 고조와 관련된 공급 차질 우려가 영향을 미친 것으로 보입니다. 그러나 사료 및 비료 관련 종목들이 급등하는 상황 속에서 한일사료의 하락은 다소 의외로, 시장의 전반적인 혼조세가 반영된 것으로 해석됩니다.","content_url":"https://www.hankyung.com/article/2026071434676","publisher":"한국경제","polarity":null,"change_rate":-2.71,"created_at":"2026-07-14T09:43:00.000000"},{"code":"005860","date":"2026-07-13","company_name":"한일사료","article_title":null,"briefing":"한일사료의 주가가 2480.0원으로 1.43% 상승하였습니다. 이러한 변동에 대한 공식적인 뉴스나 발표는 아직 확인되지 않았습니다.","content_url":null,"publisher":null,"polarity":null,"change_rate":1.43,"created_at":"2026-07-13"},{"code":"005860","date":"2026-07-10","company_name":"한일사료","article_title":null,"briefing":"한일사료의 주가가 2445.0원으로 0.62% 상승하였습니다. 이러한 변동에 대한 공식적인 뉴스나 발표는 아직 확인되지 않았습니다.","content_url":null,"publisher":null,"polarity":null,"change_rate":0.62,"created_at":"2026-07-10"},{"code":"005860","date":"2026-07-09","company_name":"한일사료","article_title":null,"briefing":"한일사료의 주가가 2430.0원으로 1.89% 상승하였습니다. 이러한 변동에 대한 공식적인 뉴스나 발표는 아직 확인되지 않았습니다.","content_url":null,"publisher":null,"polarity":null,"change_rate":1.89,"created_at":"2026-07-09"},{"code":"005860","date":"2026-07-08","company_name":"한일사료","article_title":null,"briefing":"한일사료의 주가가 2385.0원으로 0.21% 상승하였습니다. 이러한 변동에 대한 공식적인 뉴스나 발표는 아직 확인되지 않았습니다.","content_url":null,"publisher":null,"polarity":null,"change_rate":0.21,"created_at":"2026-07-08"},{"code":"005860","date":"2