[{"code":"006050","date":"2026-06-23","company_name":"국영지앤엠","article_title":"3대 잇는 유리 명가, 100년을 겨눈다","briefing":"국영지앤엠의 주가가 0.95% 상승하여 531원에 마감되었습니다. 주가 상승은 리모델링 및 재건축, 재개발 시장의 성장 기대감에 기인한 것으로 보입니다. 그러나 전체적인 변동률이 크지 않았으므로, 향후 시장 상황을 주의 깊게 살펴볼 필요가 있습니다.","content_url":"https://www.donga.com/news/Economy/article/all/20260622/134146724/2","publisher":"동아일보","polarity":null,"change_rate":0.95,"created_at":"2026-06-23T04:34:00.000000"},{"code":"006050","date":"2026-06-22","company_name":"국영지앤엠","article_title":null,"briefing":"국영지앤엠의 주가가 526.0원으로 -8.68% 하락하였습니다. 이러한 변동에 대한 공식적인 뉴스나 발표는 아직 확인되지 않았습니다.","content_url":null,"publisher":null,"polarity":null,"change_rate":-8.68,"created_at":"2026-06-22"},{"code":"006050","date":"2026-06-15","company_name":"국영지앤엠","article_title":"국영지앤엠, 10대 1 주식병합 결정","briefing":"국영지앤엠의 주가가 22.35% 하락하여 535원에 마감되었습니다. 주식병합 결정이 발표되면서 투자자들의 우려가 커진 것으로 보입니다. 주식병합이 기업가치를 유지한다고 하더라도, 단기적인 주가 하락 압력이 작용한 것으로 분석됩니다.","content_url":"https://www.edaily.co.kr/news/newspath.asp?newsid=04782246645481064","publisher":"이데일리","polarity":"중립","change_rate":-22.35,"created_at":"2026-06-12T16:06:00.000000"},{"code":"006050","date":"2026-06-12","company_name":"국영지앤엠","article_title":null,"briefing":"국영지앤엠의 주가가 689.0원으로 2.68% 상승하였습니다. 이러한 변동에 대한 공식적인 뉴스나 발표는 아직 확인되지 않았습니다.","content_url":null,"publisher":null,"polarity":null,"change_rate":2.68,"created_at":"2026-06-12"},{"code":"006050","date":"2026-06-11","company_name":"국영지앤엠","article_title":null,"briefing":"국영지앤엠의 주가가 671.0원으로 -1.47% 하락하였습니다. 이러한 변동에 대한 공식적인 뉴스나 발표는 아직 확인되지 않았습니다.","content_url":null,"publisher":null,"polarity":null,"change_rate":-1.47,"created_at":"2026-06-11"},{"code":"006050","date":"2026-06-10","company_name":"국영지앤엠","article_title":null,"briefing":"국영지앤엠의 주가가 681.0원으로 -5.94% 하락하였습니다. 이러한 변동에 대한 공식적인 뉴스나 발표는 아직 확인되지 않았습니다.","content_url":null,"publisher":null,"polarity":null,"change_rate":-5.94,"created_at":"2026-06-10"},{"code":"006050","date":"2026-06-09","company_name":"국영지앤엠","article_