[{"code":"008420","date":"2026-06-17","company_name":"문배철강","article_title":"중동 재건 기대감에 'K-스틸법' 시행…철강주 일제히 '불기둥'","briefing":"문배철강의 주가가 2.70% 상승하여 2,280원에 마감되었습니다. 주가 상승은 중동 재건 사업에 대한 기대감이 반영된 것으로 보이며, 특히 미국과 이란 간의 종전 합의가 철강 수요 증가로 이어질 것이라는 전망이 긍정적인 영향을 미쳤습니다. 이러한 재건 사업은 철강 관련 기업들에게 기회가 될 것으로 예상됩니다.","content_url":"https://www.mt.co.kr/stock/2026/06/17/2026061710343829318","publisher":"머니투데이","polarity":null,"change_rate":2.7,"created_at":"2026-06-17T14:18:00.000000"},{"code":"008420","date":"2026-06-16","company_name":"문배철강","article_title":"문배철강, 오너가 세 자매 잇단 지분 매입 '눈길'","briefing":"문배철강의 주가가 0.67% 하락하여 2,220원에 마감되었습니다. 이 하락세는 특별한 외부 요인 없이 진행된 것으로 보입니다. 그러나 오너가 세 자매의 지분 매입 소식이 있었으며, 이는 향후 지배구조에 대한 관심을 불러일으킬 수 있습니다.","content_url":"https://www.bloter.net/news/articleView.html?idxno=665469","publisher":"블로터","polarity":"중립","change_rate":-0.67,"created_at":"2026-06-15T15:44:15.000000"},{"code":"008420","date":"2026-06-15","company_name":"문배철강","article_title":null,"briefing":"문배철강의 주가가 2235.0원으로 0.0% 하락하였습니다. 이러한 변동에 대한 공식적인 뉴스나 발표는 아직 확인되지 않았습니다.","content_url":null,"publisher":null,"polarity":null,"change_rate":0.0,"created_at":"2026-06-15"},{"code":"008420","date":"2026-06-12","company_name":"문배철강","article_title":null,"briefing":"문배철강의 주가가 2235.0원으로 -1.32% 하락하였습니다. 이러한 변동에 대한 공식적인 뉴스나 발표는 아직 확인되지 않았습니다.","content_url":null,"publisher":null,"polarity":null,"change_rate":-1.32,"created_at":"2026-06-12"},{"code":"008420","date":"2026-06-11","company_name":"문배철강","article_title":null,"briefing":"문배철강의 주가가 2265.0원으로 -5.62% 하락하였습니다. 이러한 변동에 대한 공식적인 뉴스나 발표는 아직 확인되지 않았습니다.","content_url":null,"publisher":null,"polarity":null,"change_rate":-5.62,"created_at":"2026-06-11"},{"code":"008420","date":"2026-06-10","company_name":"문배철강","article_title":null,"briefing":"문배철강의 주가가 2400.0원으로 12.68% 상승하였습니다. 이러한 변동에 대한 공식적인 뉴스나 발표는 아직 확인되지 않았습니다.","content_url":null,"publisher":null,"polarity":null,"change_rate":12.68,"created_at":"2026-06-10"},{"code":"008420","date":"2026-06-09","