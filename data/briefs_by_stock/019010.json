[{"code":"019010","date":"2026-07-20","company_name":"베뉴지","article_title":"베뉴지, 376억 규모 교환사채권 발행 결정","briefing":"베뉴지의 주가가 2.65% 하락하여 4,040원에 마감되었습니다. 이번 하락은 376억 원 규모의 교환사채 발행 결정에 따른 것으로 보입니다. 교환사채 발행은 자금 조달을 위한 조치로, 시장에서 부정적인 신호로 해석될 수 있습니다.","content_url":"https://www.edaily.co.kr/news/newspath.asp?newsid=04906886645515176","publisher":"이데일리","polarity":"중립","change_rate":-2.65,"created_at":"2026-07-16T16:41:00.000000"},{"code":"019010","date":"2026-07-14","company_name":"베뉴지","article_title":"\"스크린치고 필드쿠폰 받으세요\"…골프존 이벤트","briefing":"베뉴지의 주가가 2.19% 상승하여 4,200원에 마감되었습니다. 그러나 이 상승세는 상대적으로 큰 변동이 아니며, 골프존의 여름 이벤트 소식이 주효했을 것으로 보입니다. 이 이벤트는 고객들에게 스크린 골프와 필드 라운드 혜택을 동시에 제공하여 골프 업계 활성화에 기여할 것으로 기대됩니다.","content_url":"https://www.newsis.com/view/NISX20260714_0003708206","publisher":"뉴시스","polarity":"중립","change_rate":2.19,"created_at":"2026-07-14T10:11:00.000000"},{"code":"019010","date":"2026-07-13","company_name":"베뉴지","article_title":null,"briefing":"베뉴지의 주가가 4110.0원으로 -10.65% 하락하였습니다. 이러한 변동에 대한 공식적인 뉴스나 발표는 아직 확인되지 않았습니다.","content_url":null,"publisher":null,"polarity":null,"change_rate":-10.65,"created_at":"2026-07-13"},{"code":"019010","date":"2026-07-10","company_name":"베뉴지","article_title":null,"briefing":"베뉴지의 주가가 4600.0원으로 2.22% 상승하였습니다. 이러한 변동에 대한 공식적인 뉴스나 발표는 아직 확인되지 않았습니다.","content_url":null,"publisher":null,"polarity":null,"change_rate":2.22,"created_at":"2026-07-10"},{"code":"019010","date":"2026-07-09","company_name":"베뉴지","article_title":null,"briefing":"베뉴지의 주가가 4500.0원으로 -3.43% 하락하였습니다. 이러한 변동에 대한 공식적인 뉴스나 발표는 아직 확인되지 않았습니다.","content_url":null,"publisher":null,"polarity":null,"change_rate":-3.43,"created_at":"2026-07-09"},{"code":"019010","date":"2026-07-08","company_name":"베뉴지","article_title":null,"briefing":"베뉴지의 주가가 4660.0원으로 -5.38% 하락하였습니다. 이러한 변동에 대한 공식적인 뉴스나 발표는 아직 확인되지 않았습니다.","content_url":null,"publisher":null,"polarity":null,"change_rate":-5.38,"created_at":"2026-07-08"},{"code":"019010","date":"2026-07-07","company_name":"베뉴지","article_ti