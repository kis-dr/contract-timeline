[{"code":"032080","date":"2026-07-22","company_name":"아즈텍WB","article_title":"아즈텍WB, 가족회사에 자사주 넘기고…2세 법인은 지분 매입","briefing":"아즈텍WB의 주가가 4.20% 상승하여 1,067원에 마감되었습니다. 이번 상승은 가족회사가 자사주를 매입하고, 자녀 법인을 통해 지분을 확보하는 등 승계와 주가 부양을 위한 조치가 긍정적으로 작용한 것으로 보입니다. 이러한 움직임은 시장에서 아즈텍WB의 안정성과 성장 가능성에 대한 기대감을 높이고 있습니다.","content_url":"https://www.bloter.net/news/articleView.html?idxno=668621","publisher":"블로터","polarity":"중립","change_rate":4.2,"created_at":"2026-07-22T15:15:00.000000"},{"code":"032080","date":"2026-07-21","company_name":"아즈텍WB","article_title":"아즈텍WB, 10억 자사주 신탁 추진…기존 보유분은 가족회사로","briefing":"아즈텍WB의 주가가 0.78% 하락하여 1,024원에 마감되었습니다. 주가는 큰 변동 없이 소폭 하락하였으나, 자사주 매입 추진 소식이 주요 이슈로 작용하였습니다. 자사주 매입은 주가 안정화에 긍정적인 영향을 미칠 수 있는 요소로 평가됩니다.","content_url":"https://www.bloter.net/news/articleView.html?idxno=668516","publisher":"블로터","polarity":"중립","change_rate":-0.78,"created_at":"2026-07-21T14:35:00.000000"},{"code":"032080","date":"2026-07-20","company_name":"아즈텍WB","article_title":null,"briefing":"아즈텍WB의 주가가 1032.0원으로 -0.19% 하락하였습니다. 이러한 변동에 대한 공식적인 뉴스나 발표는 아직 확인되지 않았습니다.","content_url":null,"publisher":null,"polarity":null,"change_rate":-0.19,"created_at":"2026-07-20"},{"code":"032080","date":"2026-07-16","company_name":"아즈텍WB","article_title":null,"briefing":"아즈텍WB의 주가가 1034.0원으로 -0.39% 하락하였습니다. 이러한 변동에 대한 공식적인 뉴스나 발표는 아직 확인되지 않았습니다.","content_url":null,"publisher":null,"polarity":null,"change_rate":-0.39,"created_at":"2026-07-16"},{"code":"032080","date":"2026-07-15","company_name":"아즈텍WB","article_title":null,"briefing":"아즈텍WB의 주가가 1038.0원으로 4.32% 상승하였습니다. 이러한 변동에 대한 공식적인 뉴스나 발표는 아직 확인되지 않았습니다.","content_url":null,"publisher":null,"polarity":null,"change_rate":4.32,"created_at":"2026-07-15"},{"code":"032080","date":"2026-07-14","company_name":"아즈텍WB","article_title":null,"briefing":"아즈텍WB의 주가가 995.0원으로 6.99% 상승하였습니다. 이러한 변동에 대한 공식적인 뉴스나 발표는 아직 확인되지 않았습니다.","content_url":null,"publisher":null,"polarity":null,"change_rate":6.99,"created_at":"2026-07-14"},{"code":"032080","date":"20