[{"code":"033830","date":"2026-07-03","company_name":"티비씨","article_title":"티비씨, 3일 주권매매거래 정지 해제","briefing":"티비씨의 주가가 15.85% 하락하여 1,683원에 마감되었습니다. 주권매매거래 정지 해제 소식에도 불구하고, 시장 전반의 약세와 반도체 수요 둔화 우려가 영향을 미친 것으로 보입니다. 이러한 외부 요인으로 인해 투자 심리가 위축되며 주가가 크게 하락한 것으로 분석됩니다.","content_url":"https://www.edaily.co.kr/news/newspath.asp?newsid=05041366645510584","publisher":"이데일리","polarity":"중립","change_rate":-15.85,"created_at":"2026-07-02T16:28:00.000000"},{"code":"033830","date":"2026-06-08","company_name":"티비씨","article_title":"거래소 \"티비씨 주권매매거래 정지\"","briefing":"티비씨의 주가가 6.02% 하락하여 406.0원에 마감되었습니다. 주권매매거래 정지 소식이 주가 하락의 주요 원인으로 작용한 것으로 보입니다. 이는 주식병합에 따른 전자등록 변경 및 말소로 인해 발생한 조치로, 투자자들의 우려를 불러일으킨 것으로 분석됩니다.","content_url":"https://www.edaily.co.kr/news/newspath.asp?newsid=05516966645478768","publisher":"이데일리","polarity":"중립","change_rate":-6.02,"created_at":"2026-06-05T16:41:11.000000"},{"code":"033830","date":"2026-06-05","company_name":"티비씨","article_title":null,"briefing":"티비씨의 주가가 432.0원으로 -2.7% 하락하였습니다. 이러한 변동에 대한 공식적인 뉴스나 발표는 아직 확인되지 않았습니다.","content_url":null,"publisher":null,"polarity":null,"change_rate":-2.7,"created_at":"2026-06-05"},{"code":"033830","date":"2026-06-04","company_name":"티비씨","article_title":null,"briefing":"티비씨의 주가가 444.0원으로 3.98% 상승하였습니다. 이러한 변동에 대한 공식적인 뉴스나 발표는 아직 확인되지 않았습니다.","content_url":null,"publisher":null,"polarity":null,"change_rate":3.98,"created_at":"2026-06-04"},{"code":"033830","date":"2026-06-02","company_name":"티비씨","article_title":null,"briefing":"티비씨의 주가가 427.0원으로 -3.17% 하락하였습니다. 이러한 변동에 대한 공식적인 뉴스나 발표는 아직 확인되지 않았습니다.","content_url":null,"publisher":null,"polarity":null,"change_rate":-3.17,"created_at":"2026-06-02"},{"code":"033830","date":"2026-06-01","company_name":"티비씨","article_title":null,"briefing":"티비씨의 주가가 441.0원으로 -2.43% 하락하였습니다. 이러한 변동에 대한 공식적인 뉴스나 발표는 아직 확인되지 않았습니다.","content_url":null,"publisher":null,"polarity":null,"change_rate":-2.43,"created_at":"2026-06-01"},{"code":"033830","date":"2026-05-29","company_name":"티비씨","arti