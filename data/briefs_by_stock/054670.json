[{"code":"054670","date":"2026-07-16","company_name":"대한뉴팜","article_title":"\"비만약 주 1회는 옛말\"…K제약사 월 1회 주사제 정조준","briefing":"대한뉴팜의 주가가 0.54% 상승하여 5,540원에 마감되었습니다. 주가 상승폭이 크지 않았지만, 비만 치료제 개발에 대한 기대감이 작용한 것으로 보입니다. 특히, 유한양행과의 공동 개발 소식이 긍정적인 영향을 미쳤을 것으로 분석됩니다.","content_url":"https://www.dailian.co.kr/news/view/1666529/","publisher":"데일리안","polarity":null,"change_rate":0.54,"created_at":"2026-07-13T15:49:00.000000"},{"code":"054670","date":"2026-07-08","company_name":"대한뉴팜","article_title":"대한뉴팜, '반려동물용' 장기지속형 항생제 출시","briefing":"대한뉴팜의 주가가 2.18% 상승하여 5,630원에 마감되었습니다. 이번 상승은 반려동물용 장기지속형 항생제 '큐베신주'의 출시 소식에 기인한 것으로 보입니다. 그러나 주가 변동률이 3% 미만으로 크지 않았음을 감안할 때, 시장의 반응은 다소 제한적이었던 것으로 해석됩니다.","content_url":"https://www.newsis.com/view/NISX20260708_0003700341","publisher":"뉴시스","polarity":"긍정","change_rate":2.18,"created_at":"2026-07-08T09:55:52.000000"},{"code":"054670","date":"2026-07-07","company_name":"대한뉴팜","article_title":null,"briefing":"대한뉴팜의 주가가 5510.0원으로 -0.36% 하락하였습니다. 이러한 변동에 대한 공식적인 뉴스나 발표는 아직 확인되지 않았습니다.","content_url":null,"publisher":null,"polarity":null,"change_rate":-0.36,"created_at":"2026-07-07"},{"code":"054670","date":"2026-07-06","company_name":"대한뉴팜","article_title":null,"briefing":"대한뉴팜의 주가가 5530.0원으로 -0.36% 하락하였습니다. 이러한 변동에 대한 공식적인 뉴스나 발표는 아직 확인되지 않았습니다.","content_url":null,"publisher":null,"polarity":null,"change_rate":-0.36,"created_at":"2026-07-06"},{"code":"054670","date":"2026-07-03","company_name":"대한뉴팜","article_title":null,"briefing":"대한뉴팜의 주가가 5550.0원으로 2.97% 상승하였습니다. 이러한 변동에 대한 공식적인 뉴스나 발표는 아직 확인되지 않았습니다.","content_url":null,"publisher":null,"polarity":null,"change_rate":2.97,"created_at":"2026-07-03"},{"code":"054670","date":"2026-07-02","company_name":"대한뉴팜","article_title":null,"briefing":"대한뉴팜의 주가가 5390.0원으로 -1.28% 하락하였습니다. 이러한 변동에 대한 공식적인 뉴스나 발표는 아직 확인되지 않았습니다.","content_url":null,"publisher":null,"polarity":null,"change_rate":-1.28,"created_at":"2026-07-02"},{"code":"054670","date":"2026-07-01","company_name":"대한뉴팜","article_title":null,"b