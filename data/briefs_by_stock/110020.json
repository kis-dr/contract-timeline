[{"code":"110020","date":"2026-07-23","company_name":"전진바이오팜","article_title":"전진바이오팜, 홈케어 사업 포트폴리오 확대","briefing":"전진바이오팜의 주가가 11.94% 상승하여 2,250원에 마감되었습니다. 이번 상승은 홈케어 사업 포트폴리오 확대와 신제품 공급 확정 소식에 기인한 것으로 보입니다. 글로벌 시장 공략을 위한 전략이 긍정적으로 작용하며, 향후 매출 증가에 대한 기대감이 반영된 결과로 분석됩니다.","content_url":"https://www.newsis.com/view/NISX20260722_0003719025","publisher":"뉴시스","polarity":"긍정","change_rate":11.94,"created_at":"2026-07-22T16:06:00.000000"},{"code":"110020","date":"2026-07-22","company_name":"전진바이오팜","article_title":"전진바이오팜 \"홈케어 신제품 공급 확대…글로벌 시장 공략\"","briefing":"전진바이오팜의 주가가 8.65% 상승하여 2,010원에 마감되었습니다. 이번 상승은 신규 홈케어 제품군 공급 확대와 글로벌 시장 공략 계획에 따른 것으로 분석됩니다. 이러한 전략은 해외 매출 비중을 높이고, 글로벌 파트너사와의 협력을 강화하는 데 기여할 것으로 기대됩니다.","content_url":"https://www.edaily.co.kr/news/newspath.asp?newsid=04077046645517144","publisher":"이데일리","polarity":"긍정","change_rate":8.65,"created_at":"2026-07-22T13:46:00.000000"},{"code":"110020","date":"2026-07-21","company_name":"전진바이오팜","article_title":null,"briefing":"전진바이오팜의 주가가 1850.0원으로 2.55% 상승하였습니다. 이러한 변동에 대한 공식적인 뉴스나 발표는 아직 확인되지 않았습니다.","content_url":null,"publisher":null,"polarity":null,"change_rate":2.55,"created_at":"2026-07-21"},{"code":"110020","date":"2026-07-20","company_name":"전진바이오팜","article_title":null,"briefing":"전진바이오팜의 주가가 1804.0원으로 2.38% 상승하였습니다. 이러한 변동에 대한 공식적인 뉴스나 발표는 아직 확인되지 않았습니다.","content_url":null,"publisher":null,"polarity":null,"change_rate":2.38,"created_at":"2026-07-20"},{"code":"110020","date":"2026-07-16","company_name":"전진바이오팜","article_title":null,"briefing":"전진바이오팜의 주가가 1762.0원으로 0.69% 상승하였습니다. 이러한 변동에 대한 공식적인 뉴스나 발표는 아직 확인되지 않았습니다.","content_url":null,"publisher":null,"polarity":null,"change_rate":0.69,"created_at":"2026-07-16"},{"code":"110020","date":"2026-07-15","company_name":"전진바이오팜","article_title":null,"briefing":"전진바이오팜의 주가가 1750.0원으로 0.98% 상승하였습니다. 이러한 변동에 대한 공식적인 뉴스나 발표는 아직 확인되지 않았습니다.","content_url":null,"publisher":null,"polarity":null,"change_rate":0.98,"created_at":"2026-07-15"},{"code":"110020","date":"