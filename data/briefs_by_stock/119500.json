sher":null,"polarity":null,"change_rate":-0.33,"created_at":"2026-06-15"},{"code":"119500","date":"2026-06-08","company_name":"포메탈","article_title":"K방산 호황에도 희비 갈린 소부장株…무기 성능 좌우할 '핵심 부품사' 질주","briefing":"포메탈의 주가가 7.92% 하락하여 2,790원에 마감되었습니다. 이번 하락은 K방산 호황에도 불구하고 포메탈의 실적에 대한 우려가 반영된 것으로 보입니다. 특히, 업계에서 부품 및 소재 업체의 주가가 대형 체계 기업에 비해 상대적으로 부진하다는 분석이 영향을 미쳤습니다.","content_url":"https://www.hankyung.com/article/2026060717451","publisher":"한국경제","polarity":null,"change_rate":-7.92,"created_at":"2026-06-07T18:35:00.000000"},{"code":"119500","date":"2026-06-05","company_name":"포메탈","article_title":null,"briefing":"포메탈의 주가가 3030.0원으로 -2.57% 하락하였습니다. 이러한 변동에 대한 공식적인 뉴스나 발표는 아직 확인되지 않았습니다.","content_url":null,"publisher":null,"polarity":null,"change_rate":-2.57,"created_at":"2026-06-05"},{"code":"119500","date":"2026-05-28","company_name":"포메탈","article_title":"중기부, 점프업 프로그램 개편…“매출 규모별 맞춤 지원”","briefing":"포메탈의 주가가 1.99% 하락하여 3,445원에 마감되었습니다. 이 하락세는 특별한 외부 요인 없이 진행된 것으로 보이며, 중소벤처기업부의 점프업 프로그램 개편 소식이 있었으나 포메탈과의 직접적인 연관성은 낮습니다. 따라서 주가는 큰 변동 없이 안정세를 유지하고 있는 상황입니다.","content_url":"https://www.edaily.co.kr/news/newspath.asp?newsid=04004886645453512","publisher":"이데일리","polarity":null,"change_rate":-1.99,"created_at":"2026-05-28T13:31:11.000000"},{"code":"119500","date":"2026-05-27","company_name":"포메탈","article_title":null,"briefing":"포메탈의 주가가 3515.0원으로 -8.46% 하락하였습니다. 이러한 변동에 대한 공식적인 뉴스나 발표는 아직 확인되지 않았습니다.","content_url":null,"publisher":null,"polarity":null,"change_rate":-8.46,"created_at":"2026-05-27"},{"code":"119500","date":"2026-05-26","company_name":"포메탈","article_title":null,"briefing":"포메탈의 주가가 3840.0원으로 -3.03% 하락하였습니다. 이러한 변동에 대한 공식적인 뉴스나 발표는 아직 확인되지 않았습니다.","content_url":null,"publisher":null,"polarity":null,"change_rate":-3.03,"created_at":"2026-05-26"},{"code":"119500","date":"2026-05-22","company_name":"포메탈","article_title":null,"briefing":"포메탈의 주가가 3960.0원으로 0.25% 상승하였습니다. 이러한 변동에 대한 공식적인 뉴스나 발표는 아직 확인되지 않았습니다.","content_url":null,"publisher":null,"polarity":null,"change_