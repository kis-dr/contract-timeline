[{"code":"192390","date":"2026-07-09","company_name":"윈하이텍","article_title":"윈하이텍, 최대주주 대상 20억원 유상증자…발행가 29% 할증","briefing":"윈하이텍의 주가가 2.28% 상승하여 1,883원에 마감되었습니다. 이번 상승은 최대주주를 대상으로 한 20억원 규모의 유상증자 결정 소식에 기인한 것으로 보입니다. 유상증자는 연구개발 및 경영 목적을 위한 자금 조달을 목적으로 하며, 주주가치 제고에 대한 긍정적인 신호로 해석될 수 있습니다.","content_url":"https://www.ddaily.co.kr/page/view/2026070815471759812","publisher":"디지털데일리","polarity":"중립","change_rate":2.28,"created_at":"2026-07-08T15:56:00.000000"},{"code":"192390","date":"2026-07-08","company_name":"윈하이텍","article_title":"윈하이텍, 20억 규모 3자배정 유증 결정…기준가보다 29% 할증 '자신감'","briefing":"윈하이텍의 주가가 2.22% 상승하여 1,841원에 마감되었습니다. 이번 상승은 20억 원 규모의 제3자배정 유상증자 결정 소식에 따른 것으로 보입니다. 유상증자는 연구개발 및 경영 목적을 위한 자금 조달을 목적으로 하며, 주주가치 제고에 대한 기대감을 반영하고 있습니다.","content_url":"https://view.asiae.co.kr/article/2026070814094245356","publisher":"아시아경제","polarity":"중립","change_rate":2.22,"created_at":"2026-07-08T14:09:00.000000"},{"code":"192390","date":"2026-07-07","company_name":"윈하이텍","article_title":"윈하이텍, 20억 규모 제3자배정 유상증자 결정","briefing":"윈하이텍의 주가가 4.95% 상승하여 1,801원에 마감되었습니다. 이 상승은 20억 원 규모의 제3자배정 유상증자 결정 소식에 따른 것으로 보입니다. 유상증자는 자본 확충을 통해 기업의 재무 건전성을 높일 수 있는 기회로 해석되며, 이는 향후 성장 가능성에 긍정적인 영향을 미칠 것으로 예상됩니다.","content_url":"https://www.edaily.co.kr/news/newspath.asp?newsid=03968806645512224","publisher":"이데일리","polarity":"중립","change_rate":4.95,"created_at":"2026-07-07T13:38:00.000000"},{"code":"192390","date":"2026-07-06","company_name":"윈하이텍","article_title":null,"briefing":"윈하이텍의 주가가 1716.0원으로 2.08% 상승하였습니다. 이러한 변동에 대한 공식적인 뉴스나 발표는 아직 확인되지 않았습니다.","content_url":null,"publisher":null,"polarity":null,"change_rate":2.08,"created_at":"2026-07-06"},{"code":"192390","date":"2026-07-03","company_name":"윈하이텍","article_title":null,"briefing":"윈하이텍의 주가가 1681.0원으로 1.63% 상승하였습니다. 이러한 변동에 대한 공식적인 뉴스나 발표는 아직 확인되지 않았습니다.","content_url":null,"publisher":null,"polarity":null,"change_rate":1.63,"created_at":"2026-07-03"},{"code":"192390","date":"2026-07-02","company_name":"윈하이텍","article_title":null,"briefing"