[{"code":"335810","date":"2026-07-22","company_name":"프리시젼바이오","article_title":"[이 시각 시황] 양대 증시 약세…정책 수혜주 부각","briefing":"프리시젼바이오의 주가가 1.44% 상승하여 1,334원에 마감되었습니다. 이 상승세는 전반적인 시장 약세 속에서도 개인 투자자들의 순매수가 이어진 데 따른 것으로 보입니다. 그러나 주가 변동이 크지 않았던 만큼, 주요 이슈는 외국인과 기관의 매도 우위가 지속되고 있다는 점입니다.","content_url":"https://biz.sbs.co.kr/article_hub/20000323527","publisher":"SBS Biz","polarity":null,"change_rate":1.44,"created_at":"2026-07-21T09:33:00.000000"},{"code":"335810","date":"2026-07-21","company_name":"프리시젼바이오","article_title":"[블루오션 동물 의료기기] ①정병곤 동물약품협회장 “인체용에서 확장한 ‘동물 전용’ 주목”","briefing":"프리시젼바이오의 주가가 3.54% 상승하여 1,315원에 마감되었습니다. 이번 상승은 동물용 의료기기 시장의 성장 가능성에 대한 기대감이 반영된 것으로 보입니다. 특히 반려동물 시장 확대와 관련된 정부의 정책이 긍정적인 영향을 미치고 있는 상황입니다.","content_url":"https://www.edaily.co.kr/news/newspath.asp?newsid=02378006645516816","publisher":"이데일리","polarity":null,"change_rate":3.54,"created_at":"2026-07-21T07:03:00.000000"},{"code":"335810","date":"2026-07-20","company_name":"프리시젼바이오","article_title":null,"briefing":"프리시젼바이오의 주가가 1270.0원으로 -14.54% 하락하였습니다. 이러한 변동에 대한 공식적인 뉴스나 발표는 아직 확인되지 않았습니다.","content_url":null,"publisher":null,"polarity":null,"change_rate":-14.54,"created_at":"2026-07-20"},{"code":"335810","date":"2026-07-16","company_name":"프리시젼바이오","article_title":null,"briefing":"프리시젼바이오의 주가가 1486.0원으로 0.13% 상승하였습니다. 이러한 변동에 대한 공식적인 뉴스나 발표는 아직 확인되지 않았습니다.","content_url":null,"publisher":null,"polarity":null,"change_rate":0.13,"created_at":"2026-07-16"},{"code":"335810","date":"2026-07-15","company_name":"프리시젼바이오","article_title":null,"briefing":"프리시젼바이오의 주가가 1484.0원으로 -0.4% 하락하였습니다. 이러한 변동에 대한 공식적인 뉴스나 발표는 아직 확인되지 않았습니다.","content_url":null,"publisher":null,"polarity":null,"change_rate":-0.4,"created_at":"2026-07-15"},{"code":"335810","date":"2026-07-14","company_name":"프리시젼바이오","article_title":null,"briefing":"프리시젼바이오의 주가가 1490.0원으로 2.69% 상승하였습니다. 이러한 변동에 대한 공식적인 뉴스나 발표는 아직 확인되지 않았습니다.","content_url":null,"publisher":null,"polarity":null,"change_rate":2.69,"created_at":"2026-07-14"},{"co