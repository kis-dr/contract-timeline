# ===========================================
# 환경변수 템플릿
# 사용법: 이 파일을 .env 로 복사한 뒤 실제 값 입력
# ⚠️ .env 는 절대 git 커밋 금지 (.gitignore 등록됨)
# ===========================================

# --- KOSCOM check API ---
KOSCOM_CUST_ID=여기에_실제_값
KOSCOM_AUTH_KEY=여기에_실제_키

# --- Gemini API ---
GEMINI_API_KEY=여기에_실제_키

# --- 레포 루트 (이 pipeline/ 의 한 단계 위 = 레포 루트 자체) ---
# 예: C:\python\kis_digital_ra\contract-timeline
REPO_ROOT=C:\python\kis_digital_ra\contract-timeline

# --- UNC 경로 ---
BRIEF_DIR=\\197.197.26.121\계량분석\★ FY26 디지털리서치사업 ★\Digital_RA\issue_briefing_by_sector\DATA
STOCK_CHECK_DIR=\\197.197.26.121\계량분석\____퀀트,로보리서치 팀 2020\로보리서치 AIR\Report\check

# --- 운영 옵션 ---
# 데이터 누적 시작일 (YYYY-MM-DD)
DATA_START_DATE=2026-06-01

# N일 이전 brief 는 연도별 zip 으로 아카이브
BRIEF_ARCHIVE_DAYS=365

# 드라이런 (실제 파일 갱신/git push 안 함)
DRY_RUN=False
